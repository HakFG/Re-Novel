generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model capitulos {
  id                 Int       @id @default(autoincrement())
  novel_id           Int?
  titulo             String    @db.VarChar(255)
  ordem              Int?
  conteudo_json      Json?
  status             String?   @default("Rascunho") @db.VarChar(50)
  palavras_contagem  Int?      @default(0)
  capitulo_pai_id    Int?
  notas_autor        String?
  data_ultima_edicao DateTime? @default(now()) @db.Timestamp(6)

  // Autorrelacionamento para ramificações
  capitulo_pai    capitulos?  @relation("capitulosTocapitulos", fields: [capitulo_pai_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  outras_versoes  capitulos[] @relation("capitulosTocapitulos")
  
  // Relação com a novel
  novels          novels?     @relation(fields: [novel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model grimorio {
  id                       Int     @id @default(autoincrement())
  novel_id                 Int?
  categoria                String? @db.VarChar(100)
  titulo                   String  @db.VarChar(255)
  conteudo                 String?
  tags                     Json?
  primeira_mencao_capitulo Int?
  imagem_url               String? @db.VarChar(255)
  
  novels                   novels? @relation(fields: [novel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model novels {
  id                  Int           @id @default(autoincrement())
  titulo              String        @db.VarChar(255)
  sinopse             String?
  genero              String?       @db.VarChar(100)
  status              String?       @default("Em Planejamento") @db.VarChar(50)
  progresso_total     Int?          @default(0)
  data_criacao        DateTime?     @default(now()) @db.Timestamp(6)
  capitulos_estimados Int?          @default(0)
  link_wattpad        String?       @db.VarChar(255)
  config_visual       Json?

  // Relações usando os nomes exatos das tabelas
  capitulos           capitulos[]
  grimorio            grimorio[]
  personagens         personagens[]
  timeline            timeline[]
}

model personagens {
  id                       Int        @id @default(autoincrement())
  novel_id                 Int?
  nome                     String     @db.VarChar(255)
  idade                    Int?
  papel                    String?    @db.VarChar(100)
  objetivo_neste_volume    String?
  primeira_mencao_capitulo String?    @db.VarChar(100)
  descricao_fisica         String?
  personalidade            String?
  tags                     Json?
  checklist_aparicoes      Json?
  data_criacao             DateTime?  @default(now()) @db.Timestamp(6)

  novels                   novels?    @relation(fields: [novel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  timeline                 timeline[]
}

model timeline {
  id                    Int          @id @default(autoincrement())
  novel_id              Int?
  evento_nome           String       @db.VarChar(255)
  descricao             String?
  capitulo_estimado     Int?
  importancia           Int?         @default(1)
  impacto_personagem_id Int?
  concluido             Boolean?     @default(false)

  // Relações
  personagens           personagens? @relation(fields: [impacto_personagem_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  novels                novels?      @relation(fields: [novel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
model mencoes {
  id                Int       @id @default(autoincrement())
  capitulo_id       Int
  novel_id          Int
  personagem_id     Int?
  grimorio_id       Int?
  tipo              String    @db.VarChar(20) // 'PERSONAGEM' ou 'GRIMORIO'
  posicao_inicio    Int       // Posição inicial no texto
  posicao_fim       Int       // Posição final no texto
  texto_mencionado  String    @db.VarChar(500) // O nome/texto que foi mencionado
  created_at        DateTime  @default(now()) @db.Timestamp(6)

  // Relações
  capitulo   capitulos   @relation(fields: [capitulo_id], references: [id], onDelete: Cascade)
  novel      novels      @relation(fields: [novel_id], references: [id], onDelete: Cascade)
  personagem personagens? @relation(fields: [personagem_id], references: [id], onDelete: SetNull)
  grimorio   grimorio?    @relation(fields: [grimorio_id], references: [id], onDelete: SetNull)

  @@index([capitulo_id])
  @@index([novel_id])
  @@index([personagem_id])
  @@index([grimorio_id])
  @@index([tipo])
  @@unique([capitulo_id, posicao_inicio]) // Evita menções duplicadas na mesma posição
}